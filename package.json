{
  "name": "melonis-uptime",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "TSX_TSCONFIG_PATH=./tsconfig.server.json tsx server.ts",
    "build": "next build --webpack",
    "start": "NODE_ENV=production TSX_TSCONFIG_PATH=./tsconfig.server.json tsx server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "TSX_TSCONFIG_PATH=./tsconfig.server.json node --import tsx --test tests/*.test.ts",
    "test:redis": "TSX_TSCONFIG_PATH=./tsconfig.server.json node --import tsx --test tests/redis.integration.test.ts",
    "test:all": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "mysql2": "^3.14.0",
    "next": "16.2.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "redis": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
